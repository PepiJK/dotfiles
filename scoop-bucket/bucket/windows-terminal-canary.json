{
    "version": "nightly-20260417",
    "description": "Windows Terminal Canary - nightly build from the main branch (portable ZIP)",
    "homepage": "https://github.com/microsoft/terminal",
    "license": "MIT",
    "notes": "This is the Canary (nightly) build. Use 'wtc' instead of 'wt' to avoid conflict with stable Windows Terminal.",
    "suggest": {
        "vcredist": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://aka.ms/terminal-canary-zip-x64#/WindowsTerminalCanary.zip"
        }
    },
    "installer": {
        "script": [
            "$winVer = [Environment]::OSVersion.Version",
            "if (($winVer.Major -lt '10') -or ($winVer.Build -lt 19041)) { error 'At least Windows 10 20H1 (build 19041) is required.'; break }",
            "",
            "# Move files from the versioned subdirectory up to $dir",
            "$subdir = Get-ChildItem $dir -Directory | Where-Object { $_.Name -match '^terminal-' } | Select-Object -First 1",
            "if ($subdir) {",
            "    Get-ChildItem $subdir.FullName | Move-Item -Destination $dir -Force",
            "    Remove-Item $subdir.FullName -Recurse -Force",
            "}",
            "",
            "# Enable portable mode",
            "if (!(Test-Path \"$persist_dir\\.portable\")) { Add-Content \"$dir\\.portable\" '' -Encoding Ascii }"
        ]
    },
    "bin": [
        [
            "WindowsTerminal.exe",
            "WindowsTerminalCanary"
        ],
        [
            "wt.exe",
            "wtc"
        ]
    ],
    "shortcuts": [
        [
            "WindowsTerminal.exe",
            "Windows Terminal Canary"
        ]
    ],
    "persist": [
        ".portable",
        "settings"
    ],
    "checkver": {
        "script": [
            "$url = 'https://aka.ms/terminal-canary-zip-x64'",
            "try {",
            "    $response = Invoke-WebRequest -Uri $url -Method Head -UseBasicParsing",
            "    $lastModified = [datetime]::Parse($response.Headers['Last-Modified'])",
            "    $version = 'nightly-' + $lastModified.ToString('yyyyMMdd')",
            "    Write-Output $version",
            "} catch {",
            "    Write-Output ''",
            "}"
        ],
        "regex": "(nightly-\\d{8})"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://aka.ms/terminal-canary-zip-x64#/WindowsTerminalCanary.zip"
            }
        }
    }
}
